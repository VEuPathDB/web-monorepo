{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "es2017",
    "module": "esnext",
    "allowJs": true,
    "noImplicitAny": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitReturns": false,
    "sourceMap": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "alwaysStrict": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "skipLibCheck": true
  }
}
